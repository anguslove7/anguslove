---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('diary'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const byYear = new Map();
for (const e of entries) {
  const y = e.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y).push(e);
}
const fmt = (d) => `${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<Base title="日记">
  {[...byYear.entries()].map(([year, list]) => (
    <section>
      <h2 class="year">{year}</h2>
      {list.map((e) => (
        <div class="entry">
          <time datetime={e.data.date.toISOString()}>{fmt(e.data.date)}</time>
          <a href={`/diary/${e.id}/`}>{e.data.title}</a>
          {e.data.weather && <span class="weather">{e.data.weather}</span>}
        </div>
      ))}
    </section>
  ))}
</Base>
