---
import '../styles/global.css';
const { title, description = '安格斯的日常记录。' } = Astro.props;
const full = title ? `${title} · Angus Love` : 'Angus Love · 日常记录';
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{full}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Angus Love" href="/rss.xml" />
    <link href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-screen-webfont@1.7.0/style.css" rel="stylesheet" />
  </head>
  <body>
    <header class="site-head">
      <a href="/" class="wordmark">Angus Love</a>
      <nav>
        <a href="/about">关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-foot">
      <div class="links">
        <a href="https://x.com/XAngus" rel="me">X</a><span>·</span><a href="https://youtube.com/@anguslove7" rel="me">YouTube</a><span>·</span><a href="https://instagram.com/anguslove" rel="me">Instagram</a><span>·</span><a href="https://facebook.com/angusloveX" rel="me">Facebook</a><span>·</span><a href="mailto:anguslove@me.com">邮箱</a><span>·</span><a href="/rss.xml">RSS</a>
      </div>
      <div class="copy">© 2026 Angus Love</div>
    </footer>
  </body>
</html>
